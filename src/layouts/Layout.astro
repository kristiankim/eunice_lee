---
import 'lenis/dist/lenis.css'
import '../styles.css'

interface Props {
  title: string
  description?: string
  robots?: string
}

const {
  title,
  description = 'Individual therapy with Eunice Lee, LCSW, online and in person in Basking Ridge, NJ. Licensed in New York and New Jersey. Support in English and Korean.',
  robots = 'index, follow',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#edeae4" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
